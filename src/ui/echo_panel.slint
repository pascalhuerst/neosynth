import { Slider, VerticalBox } from "std-widgets.slint";

component LabeledSlider {
    in property <string> label;
    in property <float> minimum: 0.0;
    in property <float> maximum: 1.0;
    in-out property <float> value: 0.0;
    callback changed(float);

    VerticalLayout {
        spacing: 2px;
        Text {
            text: root.label + ": " + root.value;
        }
        Slider {
            minimum: root.minimum;
            maximum: root.maximum;
            value <=> root.value;
            changed(v) => { root.changed(v); }
        }
    }
}

export component EchoPanel {
    callback send-changed(float);
    callback fb-local-changed(float);
    callback fb-cross-changed(float);
    callback time-l-changed(float);
    callback time-r-changed(float);
    callback lpf-changed(float);

    VerticalBox {
        Text {
            text: "Echo";
            font-size: 18px;
            horizontal-alignment: center;
        }
        LabeledSlider {
            label: "Send"; minimum: 0; maximum: 1; value: 1.0;
            changed(v) => { root.send-changed(v); }
        }
        LabeledSlider {
            label: "FB Local"; minimum: 0; maximum: 1; value: 0.4;
            changed(v) => { root.fb-local-changed(v); }
        }
        LabeledSlider {
            label: "FB Cross"; minimum: 0; maximum: 1; value: 0;
            changed(v) => { root.fb-cross-changed(v); }
        }
        LabeledSlider {
            label: "Time L (ms)"; minimum: 0; maximum: 2000; value: 400;
            changed(v) => { root.time-l-changed(v); }
        }
        LabeledSlider {
            label: "Time R (ms)"; minimum: 0; maximum: 2000; value: 300;
            changed(v) => { root.time-r-changed(v); }
        }
        LabeledSlider {
            label: "LPF (Hz)"; minimum: 200; maximum: 16000; value: 8000;
            changed(v) => { root.lpf-changed(v); }
        }
    }
}
