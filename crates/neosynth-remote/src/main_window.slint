import { ScrollView, VerticalBox, HorizontalBox, GroupBox, Slider, CheckBox } from "std-widgets.slint";

export struct ParamRow {
    path: string,
    // 0 = float, 1 = bool
    kind: int,
    label: string,
    min: float,
    max: float,
    float-value: float,
    bool-value: bool,
    /// True when this float is symmetric around zero (e.g. pan, balance).
    /// The remote renders these with a center-detent fader instead of a
    /// regular linear slider so 0 is visually distinguished.
    bipolar: bool,
}

export struct GroupRow {
    title: string,
    params: [ParamRow],
}

/// Horizontal fader for parameters symmetric around 0 (pan, balance, …).
/// Visual cues:
///   * Center tick mark on the track
///   * Fill bar grows from the center toward the thumb (left or right)
///   * Snap-to-zero detent within ~3 % of midrange so the user can find center
component BipolarFader {
    in property <float> minimum: -1;
    in property <float> maximum: 1;
    in-out property <float> value: 0;
    callback changed(float);

    height: 22px;
    min-width: 80px;

    property <float> norm: clamp((root.value - root.minimum) / (root.maximum - root.minimum), 0, 1);
    property <length> thumb-x: root.width * norm;
    property <length> center-x: root.width / 2;

    // Track
    Rectangle {
        x: 0;
        y: (parent.height - self.height) / 2;
        width: parent.width;
        height: 4px;
        background: #2a2a2e;
        border-radius: 2px;
    }

    // Fill from center toward thumb
    Rectangle {
        x: Math.min(center-x, thumb-x);
        y: (parent.height - self.height) / 2;
        width: Math.abs(thumb-x - center-x);
        height: 4px;
        background: #4a90e2;
        border-radius: 2px;
    }

    // Center tick
    Rectangle {
        x: center-x - 1px;
        y: (parent.height - self.height) / 2;
        width: 2px;
        height: 12px;
        background: #5a5a60;
    }

    // Thumb
    Rectangle {
        x: thumb-x - self.width / 2;
        y: 0;
        width: 12px;
        height: parent.height;
        background: #c8c8d0;
        border-color: #2b2b30;
        border-width: 1px;
        border-radius: 3px;
    }

    touch := TouchArea {
        property <float> drag-frac: clamp(self.mouse-x / parent.width, 0, 1);
        property <float> raw: root.minimum + drag-frac * (root.maximum - root.minimum);
        // Snap to 0 within ~3 % of full range — gives a tactile center detent.
        property <float> snap-tol: (root.maximum - root.minimum) * 0.03;
        property <float> snapped: Math.abs(raw) < snap-tol ? 0 : raw;

        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.down || self.pressed) {
                root.value = snapped;
                root.changed(snapped);
            }
        }
        moved => {
            if (self.pressed) {
                root.value = snapped;
                root.changed(snapped);
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "neosynth-remote";
    preferred-width: 700px;
    preferred-height: 760px;
    background: #16161a;

    in-out property <[GroupRow]> groups: [];
    in-out property <string> connection-status: "Connecting...";
    in-out property <float> dsp-load-pct: 0;
    in-out property <int> overrun-count: 0;
    in-out property <int> underrun-count: 0;

    callback float-changed(string, float);
    callback bool-changed(string, bool);

    VerticalBox {
        padding: 10px;
        spacing: 8px;

        // Status bar
        HorizontalBox {
            spacing: 12px;
            Text {
                text: root.connection-status;
                color: #d8d8dc;
                font-size: 12px;
                horizontal-stretch: 1;
                vertical-alignment: center;
            }
            Text {
                text: "DSP " + Math.round(root.dsp-load-pct * 10) / 10 + " %";
                color: root.dsp-load-pct > 80 ? #ff7070 : root.dsp-load-pct > 50 ? #d6c060 : #a0c0a0;
                font-size: 12px;
                vertical-alignment: center;
            }
            Text {
                text: "xrun  ovr " + root.overrun-count + "  und " + root.underrun-count;
                color: (root.overrun-count + root.underrun-count) > 0 ? #ff8080 : #707078;
                font-size: 11px;
                vertical-alignment: center;
            }
        }

        Rectangle { height: 1px; background: #2b2b30; }

        ScrollView {
            VerticalLayout {
                spacing: 6px;

                for group in root.groups: Rectangle {
                    background: #1c1c20;
                    border-radius: 4px;
                    border-color: #2b2b30;
                    border-width: 1px;
                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;
                        Text {
                            text: group.title;
                            color: #d8d8dc;
                            font-size: 13px;
                            font-weight: 700;
                        }
                        Rectangle { height: 1px; background: #2b2b30; }
                        for param[i] in group.params: HorizontalLayout {
                            spacing: 8px;
                            padding-top: 2px;
                            padding-bottom: 2px;
                            Text {
                                text: param.label;
                                color: #b8b8be;
                                width: 180px;
                                vertical-alignment: center;
                                font-size: 12px;
                            }
                            if param.kind == 0 && !param.bipolar: Slider {
                                horizontal-stretch: 1;
                                minimum: param.min;
                                maximum: param.max;
                                value: param.float-value;
                                changed(v) => {
                                    root.float-changed(param.path, v);
                                }
                            }
                            if param.kind == 0 && param.bipolar: BipolarFader {
                                horizontal-stretch: 1;
                                minimum: param.min;
                                maximum: param.max;
                                value: param.float-value;
                                changed(v) => {
                                    root.float-changed(param.path, v);
                                }
                            }
                            if param.kind == 0: Text {
                                text: Math.round(param.float-value * 100) / 100;
                                color: #909098;
                                width: 70px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                                font-size: 11px;
                            }
                            if param.kind == 1: CheckBox {
                                checked: param.bool-value;
                                horizontal-stretch: 1;
                                toggled => {
                                    root.bool-changed(param.path, self.checked);
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
