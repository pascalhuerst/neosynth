import { ScrollView, VerticalBox, HorizontalBox, Button } from "std-widgets.slint";
import { ParamPanel, FloatParam } from "param_panel.slint";
import { InputChannelStrip, FxReturnStrip, MasterStrip } from "channel_strip.slint";

export { FloatParam }

/// Initial values for one input strip — populated from persisted state.
export struct InputStripInit {
    gain_db: float,
    pan: float,
    mute: bool,
    send_reverb: float,
    send_stereo_delay: float,
    send_tape_delay: float,
    send_pre_fader: bool,
}

export struct FxReturnInit {
    gain_db: float,
    pan: float,
    mute: bool,
}

export component MainWindow inherits Window {
    title: "neosynth";
    preferred-width: 1100px;
    preferred-height: 700px;
    background: #16161a;

    in-out property <[string]> input-labels: [];
    in-out property <[float]> input-peaks: [];
    in-out property <[float]> input-rms: [];
    in-out property <[InputStripInit]> input-init: [];
    in-out property <FxReturnInit> reverb-return-init: { gain_db: 0, pan: 0, mute: false };
    in-out property <FxReturnInit> stereo-delay-return-init: { gain_db: 0, pan: 0, mute: false };
    in-out property <FxReturnInit> tape-delay-return-init: { gain_db: 0, pan: 0, mute: false };
    in-out property <float> master-init-gain-db: 0;
    in-out property <float> reverb-peak: 0;
    in-out property <float> reverb-rms: 0;
    in-out property <float> stereo-delay-peak: 0;
    in-out property <float> stereo-delay-rms: 0;
    in-out property <float> tape-delay-peak: 0;
    in-out property <float> tape-delay-rms: 0;
    in-out property <float> master-peak-l: 0;
    in-out property <float> master-rms-l: 0;
    in-out property <float> master-peak-r: 0;
    in-out property <float> master-rms-r: 0;
    /// Master compressor peak gain reduction in dB (always ≥ 0).
    in-out property <float> comp-gr-db: 0;

    /// Realtime audio thread load (% of period budget). 0 = idle, 100 = right
    /// at the limit, >100 = xrun is happening or imminent.
    in-out property <float> dsp-load-pct: 0;

    // Per-effect parameter models — populated by Rust from each effect's
    // FloatParams::all() declaration.
    in-out property <[FloatParam]> reverb-params: [];
    in-out property <[FloatParam]> stereo-delay-params: [];
    in-out property <[FloatParam]> tape-delay-params: [];
    in-out property <[FloatParam]> compressor-params: [];

    // Generic per-effect callback: (param_index, new_value).
    callback reverb-param-changed(int, float);
    callback stereo-delay-param-changed(int, float);
    callback tape-delay-param-changed(int, float);
    callback compressor-param-changed(int, float);

    // Mixer — input strips
    callback input-gain-changed(int, float);
    callback input-pan-changed(int, float);
    callback input-mute-changed(int, bool);
    callback input-send-reverb-changed(int, float);
    callback input-send-stereo-delay-changed(int, float);
    callback input-send-tape-delay-changed(int, float);
    callback input-send-pre-fader-changed(int, bool);

    // Mixer — FX returns
    callback reverb-return-gain-changed(float);
    callback reverb-return-pan-changed(float);
    callback reverb-return-mute-changed(bool);
    callback stereo-delay-return-gain-changed(float);
    callback stereo-delay-return-pan-changed(float);
    callback stereo-delay-return-mute-changed(bool);
    callback tape-delay-return-gain-changed(float);
    callback tape-delay-return-pan-changed(float);
    callback tape-delay-return-mute-changed(bool);

    // Mixer — master
    callback master-gain-changed(float);

    Rectangle {
        background: #101012;
        border-radius: 6px;

        // DSP load badge — top-right corner. Colour shifts toward red as we
        // approach the period budget so glances are enough to spot trouble.
        Rectangle {
            x: parent.width - self.width - 10px;
            y: 8px;
            width: 110px;
            height: 26px;
            border-radius: 4px;
            background: root.dsp-load-pct < 50 ? #1f2a1f
                     : root.dsp-load-pct < 80 ? #3a3320
                     : #4a1f1f;
            border-color: root.dsp-load-pct < 50 ? #2a3d2a
                       : root.dsp-load-pct < 80 ? #5a4a2a
                       : #7a2f2f;
            border-width: 1px;
            Text {
                text: "DSP " + Math.round(root.dsp-load-pct * 10) / 10 + " %";
                color: #d8d8dc;
                font-size: 12px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: 100%;
                height: 100%;
            }
        }

        ScrollView {
            HorizontalBox {
                spacing: 6px;
                padding: 8px;
                alignment: start;

                for label[i] in root.input-labels: InputChannelStrip {
                    index: i;
                    label: label;
                    meter_peak: i < root.input-peaks.length ? root.input-peaks[i] : 0;
                    meter_rms: i < root.input-rms.length ? root.input-rms[i] : 0;
                    initial_gain_db: i < root.input-init.length ? root.input-init[i].gain_db : 0;
                    initial_pan: i < root.input-init.length ? root.input-init[i].pan : 0;
                    initial_mute: i < root.input-init.length ? root.input-init[i].mute : false;
                    initial_send_reverb: i < root.input-init.length ? root.input-init[i].send_reverb : 0;
                    initial_send_stereo_delay: i < root.input-init.length ? root.input-init[i].send_stereo_delay : 0;
                    initial_send_tape_delay: i < root.input-init.length ? root.input-init[i].send_tape_delay : 0;
                    initial_send_pre_fader: i < root.input-init.length ? root.input-init[i].send_pre_fader : false;
                    gain-changed(idx, v) => { root.input-gain-changed(idx, v); }
                    pan-changed(idx, v) => { root.input-pan-changed(idx, v); }
                    mute-changed(idx, v) => { root.input-mute-changed(idx, v); }
                    send-reverb-changed(idx, v) => { root.input-send-reverb-changed(idx, v); }
                    send-stereo-delay-changed(idx, v) => { root.input-send-stereo-delay-changed(idx, v); }
                    send-tape-delay-changed(idx, v) => { root.input-send-tape-delay-changed(idx, v); }
                    send-pre-fader-changed(idx, v) => { root.input-send-pre-fader-changed(idx, v); }
                }

                Rectangle { width: 12px; }

                FxReturnStrip {
                    label: "Reverb";
                    meter_peak: root.reverb-peak;
                    meter_rms: root.reverb-rms;
                    initial_gain_db: root.reverb-return-init.gain_db;
                    initial_pan: root.reverb-return-init.pan;
                    initial_mute: root.reverb-return-init.mute;
                    gain-changed(v) => { root.reverb-return-gain-changed(v); }
                    pan-changed(v) => { root.reverb-return-pan-changed(v); }
                    mute-changed(v) => { root.reverb-return-mute-changed(v); }
                    edit-clicked => { reverb-popup.show(); }
                }
                FxReturnStrip {
                    label: "Stereo Delay";
                    meter_peak: root.stereo-delay-peak;
                    meter_rms: root.stereo-delay-rms;
                    initial_gain_db: root.stereo-delay-return-init.gain_db;
                    initial_pan: root.stereo-delay-return-init.pan;
                    initial_mute: root.stereo-delay-return-init.mute;
                    gain-changed(v) => { root.stereo-delay-return-gain-changed(v); }
                    pan-changed(v) => { root.stereo-delay-return-pan-changed(v); }
                    mute-changed(v) => { root.stereo-delay-return-mute-changed(v); }
                    edit-clicked => { stereo-delay-popup.show(); }
                }
                FxReturnStrip {
                    label: "Tape Delay";
                    meter_peak: root.tape-delay-peak;
                    meter_rms: root.tape-delay-rms;
                    initial_gain_db: root.tape-delay-return-init.gain_db;
                    initial_pan: root.tape-delay-return-init.pan;
                    initial_mute: root.tape-delay-return-init.mute;
                    gain-changed(v) => { root.tape-delay-return-gain-changed(v); }
                    pan-changed(v) => { root.tape-delay-return-pan-changed(v); }
                    mute-changed(v) => { root.tape-delay-return-mute-changed(v); }
                    edit-clicked => { tape-delay-popup.show(); }
                }

                Rectangle { width: 12px; }

                MasterStrip {
                    meter_peak_l: root.master-peak-l;
                    meter_rms_l: root.master-rms-l;
                    meter_peak_r: root.master-peak-r;
                    meter_rms_r: root.master-rms-r;
                    initial_gain_db: root.master-init-gain-db;
                    comp_gr_db: root.comp-gr-db;
                    gain-changed(v) => { root.master-gain-changed(v); }
                    comp-edit-clicked => { compressor-popup.show(); }
                }
            }
        }
    }

    reverb-popup := PopupWindow {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 460px;
        height: 540px;
        close-policy: no-auto-close;

        Rectangle {
            background: #16161a;
            border-color: #2b2b30;
            border-width: 1px;
            border-radius: 6px;

            VerticalBox {
                padding: 12px;
                spacing: 8px;

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: "Reverb";
                        font-size: 18px;
                        font-weight: 700;
                        color: #d8d8dc;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    Button {
                        text: "Close";
                        clicked => { reverb-popup.close(); }
                    }
                }

                Rectangle { height: 1px; background: #2b2b30; }

                ParamPanel {
                    float_params: root.reverb-params;
                    float_changed(idx, v) => { root.reverb-param-changed(idx, v); }
                }
            }
        }
    }

    stereo-delay-popup := PopupWindow {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 460px;
        height: 480px;
        close-policy: no-auto-close;

        Rectangle {
            background: #16161a;
            border-color: #2b2b30;
            border-width: 1px;
            border-radius: 6px;

            VerticalBox {
                padding: 12px;
                spacing: 8px;

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: "Stereo Delay";
                        font-size: 18px;
                        font-weight: 700;
                        color: #d8d8dc;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    Button {
                        text: "Close";
                        clicked => { stereo-delay-popup.close(); }
                    }
                }

                Rectangle { height: 1px; background: #2b2b30; }

                ParamPanel {
                    float_params: root.stereo-delay-params;
                    float_changed(idx, v) => { root.stereo-delay-param-changed(idx, v); }
                }
            }
        }
    }

    tape-delay-popup := PopupWindow {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 480px;
        height: 620px;
        close-policy: no-auto-close;

        Rectangle {
            background: #16161a;
            border-color: #2b2b30;
            border-width: 1px;
            border-radius: 6px;

            VerticalBox {
                padding: 12px;
                spacing: 8px;

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: "Tape Delay";
                        font-size: 18px;
                        font-weight: 700;
                        color: #d8d8dc;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    Button {
                        text: "Close";
                        clicked => { tape-delay-popup.close(); }
                    }
                }

                Rectangle { height: 1px; background: #2b2b30; }

                ParamPanel {
                    float_params: root.tape-delay-params;
                    float_changed(idx, v) => { root.tape-delay-param-changed(idx, v); }
                }
            }
        }
    }

    compressor-popup := PopupWindow {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 460px;
        height: 460px;
        close-policy: no-auto-close;

        Rectangle {
            background: #16161a;
            border-color: #2b2b30;
            border-width: 1px;
            border-radius: 6px;

            VerticalBox {
                padding: 12px;
                spacing: 8px;

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: "Compressor (Master)";
                        font-size: 18px;
                        font-weight: 700;
                        color: #d8d8dc;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    Text {
                        text: "GR -" + Math.round(root.comp-gr-db * 10) / 10 + " dB";
                        font-size: 13px;
                        color: root.comp-gr-db > 0.1 ? #d6c060 : #707078;
                        vertical-alignment: center;
                    }
                    Button {
                        text: "Close";
                        clicked => { compressor-popup.close(); }
                    }
                }

                Rectangle { height: 1px; background: #2b2b30; }

                ParamPanel {
                    float_params: root.compressor-params;
                    float_changed(idx, v) => { root.compressor-param-changed(idx, v); }
                }
            }
        }
    }
}
